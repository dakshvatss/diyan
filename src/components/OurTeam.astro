---
const teamMembers = [
  { name: 'Vishal Maheshwari', role: 'CEO', image: '/assets/vishal.png' },
  { name: 'Pratik Maheshwari', role: 'CTO', image: '/assets/pratik.png' },
  { name: 'Dimple Maheshwari', role: 'Export Director', image: '/assets/dimple.png' },
];
---

<section class="our-team-section w-full py-20 md:py-28" id="team">
  <div class="max-w-[1440px] mx-auto px-6 md:px-16">

    <!-- Section heading -->
    <h2 class="font-montserrat font-bold text-[48px] md:text-[64px] leading-none text-primary mb-14 md:mb-20">
      Our Team
    </h2>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10 justify-items-center">
      {teamMembers.map((member) => (
        <div class="team-card">
          <!-- Photo area -->
          <div class="team-card__photo">
            <img src={member.image} alt={member.name} class="team-card__photo-img" />
          </div>
          <!-- Info -->
          <div class="team-card__info">
            <h3 class="team-card__name">{member.name}</h3>
            <p class="team-card__role">{member.role}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Section background ──────────────────────────────────── */
  .our-team-section {
    background: linear-gradient(0deg, #033220, #033220), #01BCBC;
  }

  /* ── Card ─────────────────────────────────────────────────── */
  .team-card {
    position: relative;
    width: 100%;
    max-width: 344px;
    aspect-ratio: 344 / 429;
    background: #F5F5F5;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
    transition: transform 0.35s cubic-bezier(.4,0,.2,1), box-shadow 0.35s cubic-bezier(.4,0,.2,1);
  }

  .team-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.25);
  }

  /* ── Photo area ───────────────────────────────────────────── */
  .team-card__photo {
    position: absolute;
    left: 7%;
    right: 6.7%;
    top: 4.9%;
    bottom: 23.1%;
    border-radius: 12px;
    overflow: hidden;
  }

  .team-card__photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
  }

  /* ── Info block ────────────────────────────────────────────── */
  .team-card__info {
    position: absolute;
    left: 0;
    right: 0;
    top: 80.19%;
    bottom: 4.9%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 3px;
  }

  .team-card__name {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 24px;
    line-height: 29px;
    text-align: center;
    color: #000000;
    text-transform: capitalize;
    margin: 0;
  }

  .team-card__role {
    font-family: 'Darker Grotesque', sans-serif;
    font-weight: 400;
    font-size: 20px;
    line-height: 27px;
    text-align: center;
    color: #000000;
    margin: 0;
  }

  /* ── Responsive tweaks ────────────────────────────────────── */
  @media (max-width: 640px) {
    .team-card__name {
      font-size: 20px;
      line-height: 24px;
    }
    .team-card__role {
      font-size: 17px;
      line-height: 23px;
    }
  }
</style>
