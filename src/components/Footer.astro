---
---

<footer class="w-full bg-black py-14 md:py-16 mt-32 md:mt-48 relative">
  <div class="max-w-[1440px] mx-auto px-6 md:px-16">

    <!-- ── Main three-column grid ─────────────────────────────── -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-16 mb-10 md:mb-12">

      <!-- Col 1: Logo, contact, socials -->
      <div class="relative pt-[100px] md:pt-[120px]">
        <div class="absolute top-0 left-[5px] md:left-[65px] w-[196px] md:w-[266px] z-10 pointer-events-none -translate-y-[90%]">
          <img src="/assets/footer_logo.png" alt="Diyan Rice Industries Pvt ltd" class="w-full drop-shadow-xl -rotate-[10deg]" />
        </div>
        <p class="font-montserrat text-[17px] md:text-[20px] leading-[32px] text-white">
          +91 98252 57444
        </p>
        <p class="font-montserrat text-[15px] md:text-[16px] leading-[32px] text-white mb-7">
          Info@diyanrice.com
        </p>

        <!-- Social icons -->
        <div class="flex gap-3">
          <!-- LinkedIn Company -->
          <a
            href="https://www.linkedin.com/company/diyan-impex/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn Company"
            class="w-10 h-10 rounded-full border-[1.5px] border-white/25 flex items-center justify-center hover:border-white hover:bg-white/10 transition"
          >
            <svg class="w-[18px] h-[18px] text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
            </svg>
          </a>
          <!-- Facebook -->
          <a
            href="https://www.facebook.com/share/1bAR4AwX6v/?mibextid=wwXIfr"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="w-10 h-10 rounded-full border-[1.5px] border-white/25 flex items-center justify-center hover:border-white hover:bg-white/10 transition"
          >
            <svg class="w-[18px] h-[18px] text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/diyanriceind?igsh=cTVyMGc0YjVoYXNx&utm_source=qr"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="w-10 h-10 rounded-full border-[1.5px] border-white/25 flex items-center justify-center hover:border-white hover:bg-white/10 transition"
          >
            <svg class="w-[18px] h-[18px] text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849s-.011 3.585-.069 4.85c-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07s-3.584-.012-4.849-.07c-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849s.012-3.584.07-4.849c.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12s.014 3.667.072 4.947c.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072s3.667-.014 4.947-.072c4.351-.2 6.77-2.618 6.97-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.97-6.98C15.667.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4.162 4.162 0 110-8.324 4.162 4.162 0 010 8.324zM18.406 3.506a1.44 1.44 0 100 2.88 1.44 1.44 0 000-2.88z"/>
            </svg>
          </a>
          <!-- WhatsApp -->
          <a
            href="https://wa.me/919825257444"
            aria-label="WhatsApp"
            class="w-10 h-10 rounded-full border-[1.5px] border-white/25 flex items-center justify-center hover:border-white hover:bg-white/10 transition"
          >
            <svg class="w-[18px] h-[18px] text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Quick Links -->
      <div>
        <h3 class="font-montserrat font-semibold text-[18px] leading-[28px] text-white mb-5">
          Quick Links
        </h3>
        <ul class="space-y-3">
          <li>
            <a href="/" class="font-montserrat text-[16px] text-white/65 hover:text-white transition-colors">
              About Us
            </a>
          </li>

          <li>
            <a href="/our-brand" class="font-montserrat text-[16px] text-white/65 hover:text-white transition-colors">
              Our Brand
            </a>
          </li>

          <li>
            <a href="/products" class="font-montserrat text-[16px] text-white/65 hover:text-white transition-colors">
              Products
            </a>
          </li>
          
          <li>
            <a href="/contact-us" class="font-montserrat text-[16px] text-white/65 hover:text-white transition-colors">
              Contact Us
            </a>
          </li>
        </ul>
      </div>

      <!-- Col 3: Newsletter -->
      <div>
        <h3 class="font-montserrat font-semibold text-[18px] leading-[28px] text-white mb-5">
          Get product updates
        </h3>
        <p class="font-montserrat text-[14px] text-white/60 mb-4">
          Subscribe to hear about new products and export offers.
        </p>
        <form class="relative flex" onsubmit="return false;">
          <input
            type="email"
            placeholder="Your email"
            class="
              flex-1 h-12 pl-4 pr-2
              bg-white border border-black/20 rounded-l-md
              font-montserrat text-[14px] text-dark
              placeholder:text-dark/50
              focus:outline-none focus:ring-2 focus:ring-primary
            "
          />
          <button
            type="submit"
            aria-label="Subscribe"
            class="h-12 px-5 bg-primary hover:bg-green-500 rounded-r-md transition-colors flex items-center justify-center"
          >
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
            </svg>
          </button>
        </form>
      </div>

    </div>

    <!-- Divider -->
    <div class="w-full h-px bg-white/15 mb-7"></div>

    <!-- Bottom row -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-3">
      <p class="font-montserrat text-[14px] md:text-[16px] text-white/70 text-center md:text-left">
        &copy; 2026 Diyan Rice Industries Pvt ltd. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="#" class="font-montserrat text-[14px] text-white/70 hover:text-primary transition-colors">
          Privacy Policy
        </a>
        <a href="#" class="font-montserrat text-[14px] text-white/70 hover:text-primary transition-colors">
          Terms of Use
        </a>
      </div>
    </div>

  </div>
</footer>
