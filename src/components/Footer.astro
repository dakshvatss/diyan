---
---

<footer class="w-full bg-black py-14 md:py-16">
  <div class="max-w-[1440px] mx-auto px-6 md:px-16">

    <!-- ── Main three-column grid ─────────────────────────────── -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-16 mb-10 md:mb-12">

      <!-- Col 1: Logo, contact, socials -->
      <div>
        <div class="w-[130px] md:w-[150px] mb-7">
          <img src="/assets/footer_logo.png" alt="Diyan Rice Mill Industry" class="w-full" />
        </div>
        <p class="font-montserrat text-[17px] md:text-[20px] leading-[32px] text-white">
          +91 98252 57555
        </p>
        <p class="font-montserrat text-[15px] md:text-[16px] leading-[32px] text-white mb-7">
          Diyanimpex1@gmail.com
        </p>

        <!-- Social icons -->
        <div class="flex gap-3">
          <!-- LinkedIn -->
          <a
            href="#"
            aria-label="LinkedIn"
            class="w-10 h-10 rounded-full border-[1.5px] border-white/25 flex items-center justify-center hover:border-white hover:bg-white/10 transition"
          >
            <svg class="w-[18px] h-[18px] text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
            </svg>
          </a>
          <!-- Facebook -->
          <a
            href="#"
            aria-label="Facebook"
            class="w-10 h-10 rounded-full border-[1.5px] border-white/25 flex items-center justify-center hover:border-white hover:bg-white/10 transition"
          >
            <svg class="w-[18px] h-[18px] text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <!-- X / Twitter -->
          <a
            href="#"
            aria-label="X (Twitter)"
            class="w-10 h-10 rounded-full border-[1.5px] border-white/25 flex items-center justify-center hover:border-white hover:bg-white/10 transition"
          >
            <svg class="w-[18px] h-[18px] text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <!-- WhatsApp -->
          <a
            href="https://wa.me/919825257555"
            aria-label="WhatsApp"
            class="w-10 h-10 rounded-full border-[1.5px] border-white/25 flex items-center justify-center hover:border-white hover:bg-white/10 transition"
          >
            <svg class="w-[18px] h-[18px] text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Quick Links -->
      <div>
        <h3 class="font-montserrat font-semibold text-[18px] leading-[28px] text-white mb-5">
          Quick Links
        </h3>
        <ul class="space-y-3">
          <li>
            <a href="#home" class="font-montserrat text-[16px] text-white/65 hover:text-white transition-colors">
              Home
            </a>
          </li>
          <li>
            <a href="#products" class="font-montserrat text-[16px] text-white/65 hover:text-white transition-colors">
              Products
            </a>
          </li>
          <li>
            <a href="#about" class="font-montserrat text-[16px] text-white/65 hover:text-white transition-colors">
              About Us
            </a>
          </li>
          <li>
            <a href="#contact" class="font-montserrat text-[16px] text-white/65 hover:text-white transition-colors">
              Contact Us
            </a>
          </li>
        </ul>
      </div>

      <!-- Col 3: Newsletter -->
      <div>
        <h3 class="font-montserrat font-semibold text-[18px] leading-[28px] text-white mb-5">
          Get product updates
        </h3>
        <p class="font-montserrat text-[14px] text-white/60 mb-4">
          Subscribe to hear about new products and export offers.
        </p>
        <form class="relative flex" onsubmit="return false;">
          <input
            type="email"
            placeholder="Your email"
            class="
              flex-1 h-12 pl-4 pr-2
              bg-white border border-black/20 rounded-l-md
              font-montserrat text-[14px] text-dark
              placeholder:text-dark/50
              focus:outline-none focus:ring-2 focus:ring-primary
            "
          />
          <button
            type="submit"
            aria-label="Subscribe"
            class="h-12 px-5 bg-primary hover:bg-green-500 rounded-r-md transition-colors flex items-center justify-center"
          >
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
            </svg>
          </button>
        </form>
      </div>

    </div>

    <!-- Divider -->
    <div class="w-full h-px bg-white/15 mb-7"></div>

    <!-- Bottom row -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-3">
      <p class="font-montserrat text-[14px] md:text-[16px] text-white/70 text-center md:text-left">
        &copy; 2024 Diyan Rice Mill Industry. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="#" class="font-montserrat text-[14px] text-white/70 hover:text-primary transition-colors">
          Privacy Policy
        </a>
        <a href="#" class="font-montserrat text-[14px] text-white/70 hover:text-primary transition-colors">
          Terms of Use
        </a>
      </div>
    </div>

  </div>
</footer>
