---
---

<section class="w-full pt-12 pb-24 bg-white">
  <div class="max-w-[1440px] mx-auto px-6 md:px-16">
    <div class="max-w-[1321px] mx-auto">

      <!-- Heading (right-aligned on desktop) -->
      <h2 class="font-darker font-bold text-[48px] md:text-[64px] leading-tight text-secondary mb-10 md:mb-12 md:text-right">
        Our Vision
      </h2>

      <!-- ── Desktop: image left, text right ──────────────────── -->
      <div class="hidden md:grid grid-cols-2 gap-12 items-center">
        <!-- Image -->
        <div class="w-full h-[255px] rounded-[12px] overflow-hidden shadow-md">
          <img
            src="/assets/visionrice.png"
            alt="Global rice exports"
            class="w-full h-full object-cover"
          />
        </div>

        <!-- Vision copy -->
        <p class="font-montserrat font-medium text-[22px] leading-[34px] text-black">
          To become a trusted global leader in premium rice processing and exports, recognized
          for quality, consistency, and long-term partnerships. We aim to bring the authentic
          taste and richness of Indian rice to households across the world while maintaining the
          highest standards of integrity, sustainability, and excellence.
        </p>
      </div>

      <!-- ── Mobile: stacked ───────────────────────────────────── -->
      <div class="md:hidden space-y-8">
        <div class="w-full h-[220px] rounded-[12px] overflow-hidden shadow-md">
          <img
            src="/assets/visionrice.png"
            alt="Global rice exports"
            class="w-full h-full object-cover"
          />
        </div>
        <p class="font-montserrat font-medium text-[17px] leading-[30px] text-black">
          To become a trusted global leader in premium rice processing and exports, recognized
          for quality, consistency, and long-term partnerships. We aim to bring the authentic
          taste and richness of Indian rice to households across the world while maintaining the
          highest standards of integrity, sustainability, and excellence.
        </p>
      </div>

    </div>
  </div>
</section>
