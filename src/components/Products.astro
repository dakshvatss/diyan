---
const products = [
  {
    img: '/assets/1121.png',
    alt: '1121 Basmati Rice',
    title: '1121 Basmati',
    details: [
      'Extra-long grain (most popular export variety)',
      'High elongation',
      'Strong aroma',
      'Premium segment (Europe & Gulf)',
    ],
    offset: false,
  },
  {
    img: '/assets/sella.png',
    alt: 'Sella Basmati Rice',
    title: 'Sella (Parboiled) Basmati',
    details: [
      'Light golden colour',
      'Firm texture',
      'Ideal for biryani & bulk catering',
    ],
    offset: true, // 80px lower on desktop
  },
  {
    img: '/assets/steam.png',
    alt: 'Steam Basmati Rice',
    title: 'Steam Basmati',
    details: [
      'Softer than sella',
      'Bright white appearance',
      'Premium retail segment',
    ],
    offset: false,
  },
];
---

<section class="w-full py-24 bg-white" id="products">

  <!-- Section label -->
  <div class="max-w-[1440px] mx-auto px-6 md:px-16 mb-14 text-center">
    <p class="font-inter font-medium text-[15px] tracking-[0.25em] text-primary uppercase mb-3">
      What We Offer
    </p>
    <h2 class="font-montserrat font-bold text-[40px] md:text-[56px] leading-tight text-secondary">
      Our Products
    </h2>
  </div>

  <!-- ── DESKTOP: staggered absolute layout ─────────────────────────── -->
  <div class="hidden md:block max-w-[1440px] mx-auto px-16">
    <div class="relative" style="height: 680px;">

      {products.map((p, i) => (
        <div
          class="absolute w-[418px]"
          style={`
            left: ${i === 0 ? '55px' : i === 1 ? '511px' : '966px'};
            top:  ${p.offset ? '80px' : '0px'};
          `}
        >
          <!-- Card image -->
          <div class="w-full h-[346px] rounded-[20px] shadow-[4px_4px_10px_2px_rgba(128,124,124,0.25)] overflow-hidden mb-6 bg-gray-50">
            <img src={p.img} alt={p.alt} class="w-full h-full object-cover" />
          </div>

          <!-- Title -->
          <h3 class="font-montserrat font-semibold text-[26px] leading-[1.3] text-center text-black mb-3">
            {p.title}
          </h3>

          <!-- Details -->
          <ul class="space-y-1">
            {p.details.map((d) => (
              <li class="font-montserrat text-[17px] leading-[28px] text-center text-dark">
                {d}
              </li>
            ))}
          </ul>
        </div>
      ))}

    </div>
  </div>

  <!-- ── MOBILE: single-column stack ──────────────────────────────── -->
  <div class="md:hidden max-w-[1440px] mx-auto px-6 flex flex-col gap-12">
    {products.map((p) => (
      <div>
        <div class="w-full h-[260px] rounded-[20px] shadow-[4px_4px_10px_2px_rgba(128,124,124,0.25)] overflow-hidden mb-5 bg-gray-50">
          <img src={p.img} alt={p.alt} class="w-full h-full object-cover" />
        </div>
        <h3 class="font-montserrat font-semibold text-[22px] leading-snug text-center text-black mb-3">
          {p.title}
        </h3>
        <ul class="space-y-1">
          {p.details.map((d) => (
            <li class="font-montserrat text-[16px] leading-[28px] text-center text-dark">
              {d}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

</section>
