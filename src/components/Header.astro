---
---

<header class="absolute top-0 w-full bg-white shadow-sm z-50">
  <nav class="max-w-[1440px] mx-auto px-6 md:px-16 py-8 md:py-10 flex items-center">

    <!-- Logo — bigger, left-anchored -->
    <a href="#home" class="w-[100px] md:w-[130px] shrink-0">
      <!-- keep small logo for mobile; hide on md+ to avoid duplication with floating hero logo -->
      <img src="/assets/logo.png" alt="Diyan Rice Mill Industry" class="w-full md:hidden" />
    </a>

    <!-- Desktop Nav — pushed to the far right with ml-auto -->
    <ul class="hidden md:flex items-center gap-12 lg:gap-24 ml-auto">
      <li>
        <a href="#home" class="font-montserrat font-bold text-[18px] text-dark hover:text-primary transition-colors">
          Home
        </a>
      </li>
      <li>
        <a href="#products" class="font-montserrat font-bold text-[18px] text-dark hover:text-primary transition-colors">
          Products
        </a>
      </li>
      <li>
        <a href="#about" class="font-montserrat font-bold text-[18px] text-dark hover:text-primary transition-colors">
          About Us
        </a>
      </li>
      <li>
        <a href="#contact" class="font-montserrat font-bold text-[18px] text-dark hover:text-primary transition-colors">
          Contact Us
        </a>
      </li>
    </ul>

    <!-- Mobile Hamburger -->
    <button
      class="md:hidden p-3 rounded-md hover:bg-gray-100 transition ml-auto"
      id="mobile-menu-btn"
      aria-label="Open menu"
    >
      <svg class="w-6 h-6 text-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Dropdown -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 shadow-lg">
    <ul class="flex flex-col px-6 py-4 gap-4">
      <li>
        <a href="#home" class="font-montserrat font-bold text-[16px] text-dark hover:text-primary transition-colors block py-2">
          Home
        </a>
      </li>
      <li>
        <a href="#products" class="font-montserrat font-bold text-[16px] text-dark hover:text-primary transition-colors block py-2">
          Products
        </a>
      </li>
      <li>
        <a href="#about" class="font-montserrat font-bold text-[16px] text-dark hover:text-primary transition-colors block py-2">
          About Us
        </a>
      </li>
      <li>
        <a href="#contact" class="font-montserrat font-bold text-[16px] text-dark hover:text-primary transition-colors block py-2">
          Contact Us
        </a>
      </li>
    </ul>
  </div>
</header>
