---
---

<header class="absolute top-0 w-full bg-white shadow-sm z-50">
  <nav class="max-w-[1440px] mx-auto px-6 md:px-16 py-8 md:py-10 flex items-center">

    <!-- Logo — circular beige container on mobile, absolute large logo on desktop -->
    <a href="/" class="relative z-[10000] w-[100px] md:w-[130px] shrink-0" style="transform: translateY(20%);">
      <!-- Mobile circular beige container -->
      <div class="md:hidden absolute -top-8 -left-4 w-[160px] h-[160px] bg-beige rounded-full flex items-center justify-center shadow-md">
        <img src="/assets/logo.png" alt="Diyan Rice Mill Industry" class="w-[120px]" />
      </div>
    </a>

    <!-- Floating logo overlay (Desktop only) -->
    <div class="hidden md:block absolute left-[61px] -top-[52px] md:left-[80px] md:-top-[60px] w-[288px] h-[288px] z-[9999] pointer-events-none" style="transform: translateY(27%);">
      <img src="/assets/logo.png" alt="Diyan Rice Mill Industry" class="w-full h-full object-contain drop-shadow-2xl" />
    </div>

    <!-- Desktop Nav — pushed to the far right with ml-auto -->
    <ul class="hidden md:flex items-center gap-12 lg:gap-24 ml-auto">

       <li>
        <a href="/" class="font-montserrat font-bold text-[18px] text-dark hover:text-primary transition-colors">
          About Us
        </a>
      </li>

      <li>
        <a href="/our-brand" class="font-montserrat font-bold text-[18px] text-dark hover:text-primary transition-colors">
          Our Brand
        </a>
      </li>

      <li>
        <a href="/products" class="font-montserrat font-bold text-[18px] text-dark hover:text-primary transition-colors">
          Products
        </a>
      </li>
     
      <li>
        <a href="/contact-us" class="font-montserrat font-bold text-[18px] text-dark hover:text-primary transition-colors">
          Contact Us
        </a>
      </li>
    </ul>

    <!-- Mobile Hamburger -->
    <button
      class="md:hidden p-3 rounded-md hover:bg-gray-100 transition ml-auto"
      id="mobile-menu-btn"
      aria-label="Open menu"
    >
      <svg class="w-6 h-6 text-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Dropdown -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 shadow-lg">
    <ul class="flex flex-col px-6 py-4 gap-4">
      <li>
        <a href="/" class="font-montserrat font-bold text-[16px] text-dark hover:text-primary transition-colors block py-2">
          About Us
        </a>
      </li>
      <li>
        <a href="/our-brand" class="font-montserrat font-bold text-[16px] text-dark hover:text-primary transition-colors block py-2">
          Our Brand
        </a>
      </li>
      <li>
        <a href="/products" class="font-montserrat font-bold text-[16px] text-dark hover:text-primary transition-colors block py-2">
          Products
        </a>
      </li>
      <li>
        <a href="/contact-us" class="font-montserrat font-bold text-[16px] text-dark hover:text-primary transition-colors block py-2">
          Contact Us
        </a>
      </li>
    </ul>
  </div>
</header>
