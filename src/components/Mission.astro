---
const missionPoints = [
  'Deliver superior-quality Basmati and Non-Basmati rice through advanced milling and strict quality control',
  'Build strong and transparent relationships with farmers, suppliers, and global buyers',
  'Ensure timely delivery and customized packaging solutions to meet diverse market demands',
  'Continuously improve our processes through technology, innovation, and sustainable practices',
  'Maintain ethical business values and customer satisfaction as our top priority',
  'To become a trusted global leader in premium rice processing and exports, recognized for quality, consistency, and long-term partnerships.',
  'We aim to bring the authentic taste and richness of Indian rice to households across the world while maintaining the highest standards of integrity, sustainability, and excellence.',
];
---

<section class="w-full pt-28 pb-20 bg-white">
  <div class="max-w-[1440px] mx-auto px-6 md:px-16">

    <!-- Two-column layoutt (heading + content) -->
    <div class="flex flex-col xl:flex-row xl:items-start gap-12 lg:gap-20">

      <!-- Left Heading -->
      <div class="xl:w-[350px] flex-shrink-0">
        <h2 class="font-darker font-bold text-[48px] md:text-[64px] leading-tight text-secondary sticky top-32">
          Our Mission
        </h2>
      </div>

      <!-- Right Content -->
      <div class="flex-1 flex flex-col items-center xl:items-stretch">

        <!-- Mission Subheading -->
        <p class="font-montserrat font-bold text-[22px] leading-[30px] text-center xl:text-left tracking-[-0.01em] text-black mb-8">
          At Diyan Rice, our mission is to:
        </p>

        <!-- Mission Points -->
        <div class="flex flex-col gap-4 w-full max-w-[900px]">
          {missionPoints.map((pt) => (
            <div class="bg-[#F7ECDC] rounded-[20px] px-6 py-8 md:px-12 md:py-10 flex items-center justify-center min-h-[120px]">
              <p class="font-montserrat font-semibold text-[18px] md:text-[22px] leading-[28px] md:leading-[30px] tracking-[-0.01em] text-center text-black">
                {pt}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ✅ Image OUTSIDE the two-column layout — full width of max-width container -->
    <img
      src="/assets/onefarmer.png"
      alt="Diyan Rice fields"
      class="block w-full mx-auto h-[390px] md:h-[490px] mt-14 object-cover rounded-[24px]"
    />

  </div>
</section>