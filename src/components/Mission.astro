---
const points = [
  'Deliver superior-quality Basmati and Non-Basmati rice through advanced milling and strict quality control',
  'Build strong and transparent relationships with farmers, suppliers, and global buyers',
  'Ensure timely delivery and customized packaging solutions to meet diverse market demands',
  'Continuously improve our processes through technology, innovation, and sustainable practices',
  'Maintain ethical business values and customer satisfaction as our top priority',
];
---

<section class="w-full pt-24 pb-12 bg-white">
  <div class="max-w-[1440px] mx-auto px-6 md:px-16">
    <div class="max-w-[1321px] mx-auto">

      <!-- Heading -->
      <h2 class="font-darker font-bold text-[48px] md:text-[64px] leading-tight text-secondary mb-10 md:mb-12">
        Our Mission
      </h2>

      <!-- ── Desktop: text left, image right ──────────────────── -->
      <div class="hidden md:grid grid-cols-2 gap-12 items-center">
        <!-- Mission bullets -->
        <div class="font-montserrat font-medium text-[20px] leading-[32px] text-black">
          <p class="mb-6">At Diyan Rice Mill Industry, our mission is to:</p>
          <ul class="space-y-4">
            {points.map((pt) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 flex-shrink-0 w-2 h-2 rounded-full bg-primary"></span>
                {pt}
              </li>
            ))}
          </ul>
        </div>

        <!-- Image -->
        <div class="w-full h-[255px] rounded-[12px] overflow-hidden shadow-md">
          <img
            src="/assets/stepgrass.png"
            alt="Rice paddy fields"
            class="w-full h-full object-cover"
          />
        </div>
      </div>

      <!-- ── Mobile: stacked ───────────────────────────────────── -->
      <div class="md:hidden space-y-8">
        <div class="w-full h-[220px] rounded-[12px] overflow-hidden shadow-md">
          <img
            src="/assets/stepgrass.png"
            alt="Rice paddy fields"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="font-montserrat font-medium text-[17px] leading-[30px] text-black">
          <p class="mb-5">At Diyan Rice Mill Industry, our mission is to:</p>
          <ul class="space-y-4">
            {points.map((pt) => (
              <li class="flex items-start gap-3">
                <span class="mt-2 flex-shrink-0 w-2 h-2 rounded-full bg-primary"></span>
                {pt}
              </li>
            ))}
          </ul>
        </div>
      </div>

    </div>
  </div>
</section>
