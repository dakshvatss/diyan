---
---

<section class="w-full bg-secondary py-20 md:py-24" id="contact">
  <div class="max-w-[1440px] mx-auto px-6 md:px-16">

    <!-- Heading -->
    <h2 class="font-montserrat font-bold text-[36px] md:text-[48px] leading-tight text-center text-white mb-10">
      Contact us
    </h2>

    <!-- Contact info block -->
    <div class="max-w-[1042px] mx-auto text-center mb-12 space-y-3">
      <p class="font-montserrat font-semibold text-[15px] md:text-[17px] text-primary uppercase tracking-widest">
        Industry Address
      </p>
      <p class="font-montserrat font-medium text-[15px] md:text-[18px] leading-relaxed text-white">
        Plot no-6, Mithi Rohar, Gandhidham, Mundra Port, Gujarat INDIA 370201
      </p>

      <p class="font-montserrat font-semibold text-[15px] md:text-[17px] text-primary uppercase tracking-widest pt-4">
        Office Address
      </p>
      <p class="font-montserrat font-medium text-[15px] md:text-[18px] leading-relaxed text-white">
        Radhe infinity, near GIFT city, Ahmedabad, Gujarat INDIA
      </p>

      <div class="pt-4 space-y-2">
        <p class="font-montserrat font-medium text-[15px] md:text-[18px] text-white">
          <a href="mailto:diyanimpex1@gmail.com" class="hover:text-primary transition-colors">
            Diyanimpex1@gmail.com
          </a>
        </p>
        <p class="font-montserrat font-medium text-[15px] md:text-[18px] text-white">
          <a href="tel:+919825257555" class="hover:text-primary transition-colors">
            +91 98252 57555 &nbsp;(WhatsApp / Call)
          </a>
        </p>
      </div>
    </div>

    <!-- Contact Form — Web3Forms -->
    <form
      action="https://api.web3forms.com/submit"
      method="POST"
      class="w-full max-w-[1043px] mx-auto space-y-5"
    >
      <!-- Replace with your free key from https://web3forms.com -->
      <input type="hidden" name="access_key" value="70edfb16-9116-459f-bb1b-d7cdef1429a5" />
      <input type="hidden" name="subject" value="New enquiry — Diyan Rice Mill" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

      <!-- Row 1 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <input
          type="text"
          name="name"
          placeholder="Name"
          required
          class="w-full h-[55px] px-6 bg-white rounded-[7px] font-montserrat font-semibold text-[15px] text-black placeholder:text-black/50 focus:outline-none focus:ring-2 focus:ring-primary"
        />
        <input
          type="tel"
          name="phone"
          placeholder="Contact number"
          class="w-full h-[55px] px-6 bg-white rounded-[7px] font-montserrat font-semibold text-[15px] text-black placeholder:text-black/50 focus:outline-none focus:ring-2 focus:ring-primary"
        />
      </div>

      <!-- Row 2 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <input
          type="email"
          name="email"
          placeholder="Email"
          required
          class="w-full h-[55px] px-6 bg-white rounded-[7px] font-montserrat font-semibold text-[15px] text-black placeholder:text-black/50 focus:outline-none focus:ring-2 focus:ring-primary"
        />
        <input
          type="text"
          name="city"
          placeholder="City"
          class="w-full h-[55px] px-6 bg-white rounded-[7px] font-montserrat font-semibold text-[15px] text-black placeholder:text-black/50 focus:outline-none focus:ring-2 focus:ring-primary"
        />
      </div>

      <!-- Row 3: Message -->
      <textarea
        name="message"
        placeholder="Your message"
        rows="5"
        required
        class="w-full h-[155px] px-6 py-4 bg-white rounded-[7px] font-montserrat font-semibold text-[15px] text-black placeholder:text-black/50 resize-none focus:outline-none focus:ring-2 focus:ring-primary"
      ></textarea>

      <!-- Submit -->
      <div class="flex justify-center pt-4">
        <button
          type="submit"
          class="w-full md:w-[260px] h-[68px] bg-primary hover:bg-green-500 rounded-[92px] font-montserrat font-bold text-[20px] md:text-[24px] text-white transition-colors"
        >
          Contact Us
        </button>
      </div>
    </form>

  </div>
</section>
