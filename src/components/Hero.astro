---
---

<section class="relative min-h-[500px] md:h-[749px] mt-0 md:mt-0 flex flex-col md:block" id="home">

  <!-- Background Image: Absolute on desktop, relative height on mobile -->
  <div class="relative md:absolute inset-0 w-full h-[500px] md:h-full">
    <img
      src="/assets/29.jpeg"
      alt="Rice Paddy Field"
      class="w-full h-full object-cover object-center"
    />
    <!-- subtle dark overlay for readability on small screens - only if absolute -->
    <div class="absolute inset-0 bg-black/10 md:bg-transparent md:hidden"></div>
  </div>


  <!-- Content Box -->
  <div
    class="
      relative z-10 flex items-center
      md:absolute md:inset-0
      px-0 md:px-0
      justify-center md:justify-end
      md:pr-[calc((100vw-1440px)/2+80px)]
      bg-secondary md:bg-transparent
      py-12 md:py-0
    "
  >
    <!-- Green Box -->
    <div
      class="
        w-full
        md:w-[689px] md:h-[443px]
        bg-secondary md:rounded-[20px]
        px-6 py-10 md:p-10
        flex flex-col justify-between
        md:shadow-2xl
      "
    >
      <!-- Heading -->
      <h1
        class="font-montserrat font-semibold text-[32px] md:text-[42px] leading-tight md:leading-[51px] tracking-[2px] md:tracking-[3px] text-white"
      >
        Premium Exporter of<br />
        <span class="inline-block text-[56px] md:text-[74px] font-bold leading-[0.9] md:leading-[65px] text-[#FFFEFE] mt-2">
          Basmati Rice
        </span>
      </h1>

      <!-- Body copy -->
      <p
        class="font-montserrat font-medium text-[16px] md:text-[20px] leading-[26px] md:leading-[30px] lg:leading-[34px] text-white/90 mt-8 md:mt-4"
      >
        Basmati is a premium long-grain rice variety traditionally grown in the
        Himalayan foothills of India. The word "Basmati" means "fragrant",
        which reflects its naturally rich aroma and delicate flavor.
      </p>
    </div>
  </div>
</section>
