---
---

<section class="relative h-[749px] mt-[80px] md:mt-[100px] overflow-hidden" id="home">

  <!-- Background Image — full bleed -->
  <div class="absolute inset-0 w-full h-full">
    <img
      src="/assets/Hero.png"
      alt="Rice Paddy Field"
      class="w-full h-full object-cover object-center"
    />
    <!-- subtle dark overlay for readability on small screens -->
    <div class="absolute inset-0 bg-black/20 md:bg-transparent"></div>
  </div>

  <!-- Content: centred on mobile, right-positioned on desktop -->
  <div
    class="
      relative z-10 flex items-center h-full
      px-6 md:px-0
      justify-center md:justify-end
      md:pr-[calc((100vw-1440px)/2+80px)]
    "
  >
    <!-- Green Box -->
    <div
      class="
        w-full max-w-[95vw]
        md:w-[689px] md:h-[443px]
        bg-secondary rounded-[20px]
        p-8 md:p-10
        flex flex-col justify-between
        shadow-2xl
      "
    >
      <!-- Heading -->
      <h1
        class="font-montserrat font-semibold text-[28px] md:text-[42px] leading-tight md:leading-[51px] tracking-[2px] md:tracking-[3px] text-white"
      >
        Premium Exporter of<br />Basmati Rice
      </h1>

      <!-- Body copy -->
      <p
        class="font-montserrat font-medium text-[16px] md:text-[20px] leading-[30px] md:leading-[34px] text-white/90 mt-4"
      >
        Basmati is a premium long-grain rice variety traditionally grown in the
        Himalayan foothills of India. The word "Basmati" means "fragrant",
        which reflects its naturally rich aroma and delicate flavor.
      </p>
    </div>
  </div>
</section>
