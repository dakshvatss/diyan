---
const testimonials = [
  {
    name: 'Global Foods Co.',
    text: "We've been sourcing rice from Diyan for over a year now, and the quality has been consistently excellent. The grains are clean, well-processed, and exactly as promised. Our customers have noticed the difference, and so have our repeat orders.",
    cardBg: '#48D44F',
    nameColor: '#000',
    textColor: '#fff',
    avatar: '/assets/a1.png',
    avatarBorder: '#fff',
  },
  {
    name: 'Elite Rice Importers',
      text: "As a wholesaler, pricing and reliability are everything—and Diyan delivers on both. Their bulk rates are competitive, and the team is always responsive when it comes to large or urgent orders. It's been a smooth partnership.",
    cardBg: '#033220',
    nameColor: '#fff',
    textColor: '#fff',
    avatar: '/assets/a2.png',
    avatarBorder: '#fff',
  },
  {
    name: 'Fresh Mart Solutions',
      text: "What sets Diyan apart is not just the product quality but their professionalism. Orders are always delivered on time, well-packaged, and exactly as expected. It's rare to find such dependable service in this industry.",
    cardBg: '#48D44F',
    nameColor: '#000',
    textColor: '#000',
    avatar: '/assets/a3.png',
    avatarBorder: '#fff',
  },
  {
    name: 'Premium Grain Traders',
    text: "We've been sourcing rice from Diyan for over a year now, and the quality has been consistently excellent. The grains are clean, well-processed, and exactly as promised. Our customers have noticed the difference, and so have our repeat orders.",
    cardBg: '#033220',
    nameColor: '#fff',
    textColor: '#fff',
    avatar: '/assets/a1.png',
    avatarBorder: '#fff',
  },
  {
    name: 'Nature\'s Harvest Ltd.',
    text: "We've been sourcing rice from Diyan for over a year now, and the quality has been consistently excellent. The grains are clean, well-processed, and exactly as promised. Our customers have noticed the difference, and so have our repeat orders.",
    cardBg: '#48D44F',
    nameColor: '#000',
    textColor: '#000',
    avatar: '/assets/a2.png',
    avatarBorder: '#fff',
  },
];
---

<section class="w-full py-20 md:py-24 bg-white overflow-hidden">
  <div class="max-w-[1440px] mx-auto">

    <!-- Heading -->
    <h2 class="font-montserrat font-semibold text-[26px] md:text-[42px] leading-snug md:leading-[52px] text-center text-black mb-14 max-w-[976px] mx-auto px-6">
      What our clients say about Diyan Rice Industries Pvt ltd
    </h2>

    <!-- Carousel Container -->
    <div 
      id="testimonial-carousel"
      class="flex justify-start items-start gap-8 mb-13 overflow-x-auto snap-x snap-mandatory pb-8 scrollbar-hide testimonial-container px-6 md:px-16"
    >
      {testimonials.map((t, i) => (
        <div 
          class="testimonial-card-wrapper transition-all duration-500 ease-in-out testimonial-card-wrapper--wide"
          data-index={i}
        >
          <div class="testimonial-avatar" style={`border-color: ${t.avatarBorder};`}>
            <img
              src={t.avatar}
              alt={t.name}
              class="testimonial-avatar__img"
            />
          </div>
          <div class="testimonial-card" style={`background: ${t.cardBg};`}>
            <div>
              <h3 class="testimonial-card__name" style={`color: ${t.nameColor};`}>
                {t.name}
              </h3>
              <p class="testimonial-card__text" style={`color: ${t.textColor};`}>
                {t.text}
              </p>
            </div>
            <div class="testimonial-card__stars">
              {[1,2,3,4,5].map(() => (
                <span class="testimonial-star">★</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Pagination dots -->
    <div id="testimonial-dots" class="flex justify-center gap-5 mt-8 px-6">
      {testimonials.map((_, i) => (
        <button
          class={`testimonial-dot w-[13px] h-[13px] rounded-full transition-all duration-300 ${i === 0 ? 'bg-secondary' : 'bg-black/40'}`}
          aria-label={`Go to testimonial ${i + 1}`}
          data-index={i}
        ></button>
      ))}
    </div>

  </div>
</section>

<script>
  function initCarousel() {
    const carousel = document.getElementById('testimonial-carousel');
    const dots = document.querySelectorAll('.testimonial-dot');
    const cards = document.querySelectorAll('.testimonial-card-wrapper');
    
    if (!carousel || dots.length === 0) return;

    const updateActiveState = () => {
      const scrollLeft = carousel.scrollLeft;
      const carouselRect = carousel.getBoundingClientRect();
      const carouselPadding = parseFloat(window.getComputedStyle(carousel).paddingLeft);
      
      // We want to find which card is at the start (accounting for padding)
      let activeIndex = 0;
      let minDiff = Infinity;

      cards.forEach((card, index) => {
        const cardOffset = (card as HTMLElement).offsetLeft - carouselPadding;
        const diff = Math.abs(cardOffset - scrollLeft);
        
        if (diff < minDiff) {
          minDiff = diff;
          activeIndex = index;
        }
      });

      // Update dots
      dots.forEach((dot, index) => {
        if (index === activeIndex) {
          dot.classList.add('bg-secondary');
          dot.classList.remove('bg-black/40');
        } else {
          dot.classList.remove('bg-secondary');
          dot.classList.add('bg-black/40');
        }
      });
    };

    // Scroll listener
    carousel.addEventListener('scroll', updateActiveState);

    // Click listener
    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        const index = parseInt(dot.getAttribute('data-index'));
        const card = cards[index] as HTMLElement;
        const carouselPadding = parseFloat(window.getComputedStyle(carousel).paddingLeft);
        
        carousel.scrollTo({
          left: card.offsetLeft - carouselPadding,
          behavior: 'smooth'
        });
      });
    });

    // Initial run
    updateActiveState();
  }

  document.addEventListener('DOMContentLoaded', initCarousel);
  document.addEventListener('astro:after-swap', initCarousel);
</script>

<style>
  /* ── Container ─────────────────────────────────────────── */
  .testimonial-container {
    -ms-overflow-style: none;
    scrollbar-width: none;
    cursor: grab;
  }
  .testimonial-container:active {
    cursor: grabbing;
  }
  .testimonial-container::-webkit-scrollbar {
    display: none;
  }

  /* ── Card wrapper ──────────────────────────────────────── */
  .testimonial-card-wrapper {
    position: relative;
    flex: 0 0 auto;
    width: 36vw; /* Adjusted for ~2.5 cards on desktop */
    max-width: 890px;
    min-width: 300px;
    padding-top: 91px;
    snap-align: start;
    transform-origin: center center;
  }

  .testimonial-card-wrapper--wide {
    /* Kept for semantic consistency */
  }

  /* ── Avatar ────────────────────────────────────────────── */
  .testimonial-avatar {
    position: absolute;
    top: 0;
    left: 15%; /* Shifted slightly to account for centering look */
    transform: translateX(-50%);
    z-index: 2;
    width: 220px;
    height: 220px;
    border-radius: 50%;
    border: 16px solid;
    background: #e5e7eb;
    overflow: hidden;
    box-shadow: 0 5px 26px rgba(0,0,0,0.12);
  }

  .testimonial-avatar__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Card body ─────────────────────────────────────────── */
  .testimonial-card {
    position: relative;
    border-radius: 23px;
    padding: 117px 36px 26px;
    min-height: 420px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .testimonial-card__name {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 26px;
    line-height: 36px;
    margin: 20px 0 16px;
  }

  .testimonial-card__text {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 31px;
    margin-top: 20px;
    margin-bottom: 0px;
  }

  /* ── Stars ──────────────────────────────────────────────── */
  .testimonial-card__stars {
    display: flex;
    gap: 4px;
    margin-top: 26px;
  }

  .testimonial-star {
    color: #FFD25E;
    font-size: 29px;
    line-height: 1;
  }

  /* ── Mobile tweaks ─────────────────────────────────────── */
  @media (max-width: 768px) {
    .testimonial-card-wrapper {
      width: 80vw;
      min-width: 280px;
      padding-top: 78px;
    }
    .testimonial-avatar {
      width: 156px;
      height: 156px;
      left: 20%;
    }
    .testimonial-card {
      padding-top: 99px;
      padding-left: 24px;
      padding-right: 24px;
      min-height: 380px;
    }
  }
</style>
