---
const testimonials = [
  {
    name: 'Lorem Ipsum Has',
    text: "Lorem Ipsum Is Simply Dummy Text Of The Printing And Typesetting Industry. Lorem Ipsum Has Been The Industry's Standard Dummy Text Ever Since The 1500s.❤️",
    cardBg: '#48D44F',
    nameColor: '#000',
    textColor: '#fff',
    avatar: '/assets/vishal.png',
    avatarBorder: '#fff',
  },
  {
    name: 'Lorem Ipsum Has',
    text: "Lorem Ipsum Is Simply Dummy Text Of The Printing And Typesetting Industry. Lorem Ipsum Has Been The Industry's Standard Dummy Text Ever Since The 1500s.❤️",
    cardBg: '#033220',
    nameColor: '#fff',
    textColor: '#fff',
    avatar: '/assets/dimple.png',
    avatarBorder: '#fff',
  },
  {
    name: 'Lorem Ipsum',
    text: "Lorem Ipsum Is Simply Been The Industry's Since The 1500s.❤️",
    cardBg: '#48D44F',
    nameColor: '#000',
    textColor: '#000',
    avatar: '/assets/pratik.png',
    avatarBorder: '#fff',
  },
];
---

<section class="w-full py-20 md:py-24 bg-white">
  <div class="max-w-[1440px] mx-auto px-6 md:px-16">

    <!-- Heading -->
    <h2 class="font-montserrat font-semibold text-[26px] md:text-[42px] leading-snug md:leading-[52px] text-center text-black mb-14 max-w-[976px] mx-auto">
      What our clients say about Diyan Rice Mill Industry
    </h2>

    <!-- ── Desktop: overflow horizontal scroll (Carousel) ──────────────── -->
    <div class="hidden md:flex justify-start items-start gap-8 mb-13 overflow-x-auto snap-x snap-mandatory pb-8 scrollbar-hide testimonial-container">
      {testimonials.map((t, i) => (
        <div class={`testimonial-card-wrapper ${i === 2 ? 'testimonial-card-wrapper--narrow' : 'testimonial-card-wrapper--wide'}`}>
          <div class="testimonial-avatar" style={`border-color: ${t.avatarBorder};`}>
            <img
              src={t.avatar}
              alt={t.name}
              class="testimonial-avatar__img"
            />
          </div>
          <div class="testimonial-card" style={`background: ${t.cardBg};`}>
            <div>
              <h3 class="testimonial-card__name" style={`color: ${t.nameColor};`}>
                {t.name}
              </h3>
              <p class="testimonial-card__text" style={`color: ${t.textColor};`}>
                {t.text}
              </p>
            </div>
            <div class="testimonial-card__stars">
              {[1,2,3,4,5].map(() => (
                <span class="testimonial-star">★</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- ── Mobile: vertical stack ──────────────────────────────────── -->
    <div class="md:hidden flex flex-col gap-16 mb-13">
      {testimonials.slice(0, 2).map((t) => (
        <div class="testimonial-card-wrapper">
          <div class="testimonial-avatar" style={`border-color: ${t.avatarBorder};`}>
            <img src={t.avatar} alt={t.name} class="testimonial-avatar__img" />
          </div>
          <div class="testimonial-card" style={`background: ${t.cardBg};`}>
            <div>
              <h3 class="testimonial-card__name" style={`color: ${t.nameColor};`}>{t.name}</h3>
              <p class="testimonial-card__text" style={`color: ${t.textColor};`}>{t.text}</p>
            </div>
            <div class="testimonial-card__stars">
              {[1,2,3,4,5].map(() => (
                <span class="testimonial-star">★</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Pagination dots -->
    <div class="flex justify-center gap-5">
      <div class="w-[13px] h-[13px] bg-secondary rounded-full"></div>
      <div class="w-[13px] h-[13px] bg-black/40 rounded-full"></div>
      <div class="w-[13px] h-[13px] bg-black/40 rounded-full"></div>
    </div>

  </div>
</section>

<style>
  /* ── Card wrapper ──────────────────────────────────────── */
  .testimonial-container {
    /* Optional: Hide scrollbar for clean look */
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
  .testimonial-container::-webkit-scrollbar {
    display: none;
  }

  .testimonial-card-wrapper {
    position: relative;
    flex: 0 0 auto;           /* Don't grow or shrink, respect width */
    width: 34vw;              /* Decreased from 40vw by 20% */
    max-width: 890px;         /* Decreased from 600px by 20% */
    min-width: 300px;         /* Decreased from 450px by 20% */
    padding-top: 91px;
    snap-align: center;
  }

  .testimonial-card-wrapper--wide {
    /* Kept for semantic reasons, uses wrapper width */
  }

  .testimonial-card-wrapper--narrow {
    width: 24vw;              /* Decreased from 30vw by 20% */
    max-width: 360px;         /* Decreased from 450px by 20% */
    min-width: 280px;         /* Decreased from 350px by 20% */
  }

  /* ── Avatar ────────────────────────────────────────────── */
  .testimonial-avatar {
    position: absolute;
    top: 0;
    left: 25%;
    transform: translateX(-50%);
    z-index: 2;
    width: 220px;               /* scaled 140px by 1.3 */
    height: 220px;              /* scaled 140px by 1.3 */
    border-radius: 50%;
    border: 16px solid;          /* scaled 6px by 1.3 */
    background: #e5e7eb;
    overflow: hidden;
    box-shadow: 0 5px 26px rgba(0,0,0,0.12); /* scaled 4px/20px */
  }

  .testimonial-avatar__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Card body ─────────────────────────────────────────── */
  .testimonial-card {
    position: relative;
    border-radius: 23px;        /* scaled 18px by 1.3 */
    padding: 117px 36px 26px;   /* scaled 90px/28px by 1.3 */
    min-height: 420px;          /* scaled 300px by 1.3 */
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .testimonial-card__name {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 26px;            /* scaled 20px by 1.3 */
    line-height: 36px;          /* scaled 28px by 1.3 */
    margin: 0 0 16px;           /* scaled 12px by 1.3 */
    margin-top: 20px;
  }

  .testimonial-card__text {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 18px;            /* scaled 14px by 1.3 */
    line-height: 31px;          /* scaled 24px by 1.3 */
    margin-top: 20px;
    margin-bottom: 0px;
  }

  /* ── Stars ──────────────────────────────────────────────── */
  .testimonial-card__stars {
    display: flex;
    gap: 4px;                   /* scaled 3px by 1.3 */
    margin-top: 26px;           /* scaled 20px by 1.3 */
  }

  .testimonial-star {
    color: #FFD25E;
    font-size: 29px;            /* scaled 22px by 1.3 */
    line-height: 1;
  }

  /* ── Mobile tweaks ─────────────────────────────────────── */
  @media (max-width: 768px) {
    .testimonial-avatar {
      width: 156px;             /* scaled 120px by 1.3 */
      height: 156px;
    }
    .testimonial-card-wrapper {
      padding-top: 78px;        /* scaled 60px by 1.3 */
    }
    .testimonial-card {
      padding-top: 99px;        /* scaled 76px by 1.3 */
    }
  }
</style>
