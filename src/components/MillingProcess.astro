---
const steps = [
  {
    label: 'Cleaning',
    desc: 'Raw paddy is cleaned to remove dust, stones, and impurities.',
  },
  {
    label: 'De-husking (Husking)',
    desc: 'A machine removes the hard husk, producing brown rice.',
  },
  {
    label: 'Paddy Separation',
    desc: 'Unhusked grains are separated from brown rice and sent back for reprocessing.',
  },
  {
    label: 'Whitening / Polishing',
    desc: 'The bran layer is removed from the brown rice to create white rice, which is then polished for a better appearance.',
  },
  {
    label: 'Grading & Sorting',
    desc: 'Broken grains are separated, and color sorters remove discolored grains to ensure quality.',
  },
];
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Darker+Grotesque:wght@400;600;700;800&family=Poppins:wght@400;500&display=swap"
  rel="stylesheet"
/>

<section class="milling-section">

  <!-- Title -->
  <h2 class="milling-title">Rice Milling Process</h2>

  <!-- Process diagram image -->
  <div class="process-image-wrap">
    <img src="/assets/process.png" alt="Rice Milling Process Diagram" class="process-img" />
  </div>

  <!-- Description cards -->
  <div class="steps-list">
    {steps.map((s) => (
      <div class="step-card">
        <p class="step-text">
          <span class="step-label">{s.label}:</span> {s.desc}
        </p>
      </div>
    ))}
  </div>

  <!-- Farmers Overlap Image -->
  <img src="/assets/farmers.png" alt="Farmers working in rice field" class="farmers-full-image" />

</section>

<style>
  /* ── Section (Vector bg) ── */
  .milling-section {
    width: 100%;
    background: #F7ECDC;
    padding: 52px 0 0; /* Removed bottom padding here, moved to the image container */
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    /* Reduced margin to eliminate gap with the hanging image */
    margin-bottom: clamp(60px, 10vw, 150px); 
  }

  /* ── Title — Rice Milling Process ── */
  .milling-title {
    font-family: 'Darker Grotesque', sans-serif;
    font-style: normal;
    font-weight: 700;
    font-size: 64px;
    line-height: 60px;
    text-align: center;
    letter-spacing: -0.01em;
    color: #000000;
    width: 779px;
    max-width: calc(100% - 48px);
    margin: 0 auto 40px;
    padding: 0;
  }

  /* ── Group 3594: process diagram container ── */
  .process-image-wrap {
    width: 95%;
    max-width: 1440px;
    padding: 0;
    margin-bottom: 48px;
    box-sizing: border-box;
  }
  .process-img {
    width: 100%;
    height: auto;
    min-height: 440px;
    object-fit: contain;
    display: block;
  }

  /* ── Frame 3595: steps list ── */
  .steps-list {
    width: 95%;
    max-width: 1440px;
    padding: 0;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 16px;
    isolation: isolate;
  }

  /* ── Step card: W1170 H130 radius 20 ── */
  .step-card {
    width: 100%;
    height: 130px;
    background: #ffffff;
    border: none;
    border-radius: 20px;
    padding: 0 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
  }

  .step-text {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 22px;
    line-height: 1.75;
    color: #1d2939;
    margin: 0;
    text-align: center;
    width: 100%;
  }
  .step-label {
    font-weight: 600;
    color: #1d2939;
  }

  /* ── Farmers Overlap (Full Width) ── */
  .farmers-full-image {
    width: 100%;
    height: auto;
    display: block;
    z-index: 20;
    margin-top: 60px;
    transform: translateY(20%) scaleX(-1);
    /* This pushes the beige background "up" by 35px relative to the image */
    margin-bottom: -180px;
  }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .milling-section {
      padding: 36px 0 0;
      /* margin-bottom handled by clamp above or specific override if needed */
    }
    .milling-title {
      font-size: clamp(28px, 8vw, 48px);
      line-height: 1.05;
      margin-bottom: 28px;
    }
    .process-image-wrap {
      padding: 0 16px;
      margin-bottom: 24px;
    }
    .process-image-wrap {
      width: 94%;
      margin-bottom: 28px;
    }
    .process-img {
      min-height: unset;
    }
    .steps-list {
      width: 94%;
      padding: 0;
      gap: 12px;
    }
    .step-card {
      height: auto;
      min-height: 72px;
      padding: 18px 24px;
      border-radius: 16px;
    }
    .step-text {
      font-size: 15px;
      text-align: left;
    }
    .farmers-full-image {
      margin-top: 0;
      transform: translateY(50%) scaleX(-1);
      margin-bottom: -20px; /* Pulls next section up so beige covers top 50% */
    }
  }
</style>