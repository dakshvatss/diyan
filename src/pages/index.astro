---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import StatBanner from '../components/StatBanner.astro';
import Products from '../components/Products.astro';
import About from '../components/About.astro';
import Mission from '../components/Mission.astro';
import OurTeam from '../components/OurTeam.astro';
import Vision from '../components/Vision.astro';
import ProductShowcase from '../components/ProductShowcase.astro';
import Contact from '../components/Contact.astro';
import Testimonials from '../components/Testimonials.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Diyan Rice Mill Industry — Premium Basmati Rice Exporter"
  description="Diyan Rice Mill Industry delivers premium quality Basmati rice through advanced milling, strict quality control, and trusted export partnerships worldwide."
>
  <Header />
  <main>
    <Hero />
    <Features />
    <br> <br> 
    <!-- Logo — circular beige container on mobile, absolute large logo on desktop -->
    <a href="/" class="relative z-[10000] w-[100px] md:w-[130px] shrink-0 md:[transform:translateY(20%)]">
      <!-- Mobile circular beige container -->
      <div class="md:hidden absolute -top-8 -left-4 w-[160px] h-[160px] bg-beige rounded-full flex items-center justify-center shadow-md">
        <img src="/assets/logo.png" alt="Diyan Rice Mill Industry" class="w-[120px]" />
      </div>
    </a>
    <!-- Farmers image: sits between Products and About; About's beige will overlap from the legs -->
    <div class="w-full">
      <div class="relative z-20 w-full h-[155px] md:h-[480px] overflow-hidden">
        <img
          src="/assets/farmers.png"
          alt="Farmers working in field"
          class="w-full h-full object-cover object-center md:object-contain md:object-bottom"
        />
      </div>
    </div>

    <About />
    <StatBanner/>
    <Mission />
    <OurTeam />
    <Testimonials />
  </main>
  <Footer />
</Layout>
