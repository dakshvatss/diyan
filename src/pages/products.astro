---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductsComponent from '../components/Products.astro';
import MillingProcess from '../components/MillingProcess.astro';
import PrivateLabel from '../components/PrivateLabel.astro';
import StatBanner from '../components/StatBanner.astro';

---

<Layout
  title="Products — Diyan Rice Industries Pvt ltd"
  description="Explore our range of premium rice products."
>
  <Header />
   <div class="pt-[104px] md:pt-[120px]">
  <picture>
    <source media="(max-width: 768px)" srcset="/assets/woodricemobile.png">
    <img src="/assets/woodrice.png" alt="woodrice" class="w-full h-auto block" />
  </picture>
</div>

  <!-- Green Stat Section: Indian Basmati is globally recognized for (copied from index.html) -->
  <section class="w-full bg-primary py-16 md:py-0 md:h-[473px] flex items-center">
    <div class="max-w-[1440px] mx-auto px-6 md:px-16 w-full">
      <!-- Section Heading -->
      <h2 class="font-montserrat font-bold text-[26px] md:text-[42px] leading-tight md:leading-[51px] text-center text-white mb-10 md:mb-16">
        Indian Basmati is globally recognized for
      </h2>
      <!-- Feature Cards -->
      <div class="grid grid-cols-2 md:flex md:flex-row md:justify-center md:items-start gap-8 md:gap-[84px]">
        <div class="flex flex-col items-center gap-2 md:w-[215px]">
          <div class="w-[55px] h-[55px] mb-2 md:mb-4">
            <img src="/assets/icon1.png" alt="Extra-long slender grains" class="w-full h-full object-contain" />
          </div>
          <p class="font-montserrat font-semibold text-[16px] md:text-[22px] leading-snug md:leading-[36px] text-center text-white">
            Extra-long slender grains
          </p>
        </div>
        <div class="flex flex-col items-center gap-2 md:w-[215px]">
          <div class="w-[55px] h-[55px] mb-2 md:mb-4">
            <img src="/assets/icon2.png" alt="Distinct natural aroma" class="w-full h-full object-contain" />
          </div>
          <p class="font-montserrat font-semibold text-[16px] md:text-[22px] leading-snug md:leading-[36px] text-center text-white">
            Distinct natural aroma
          </p>
        </div>
        <div class="flex flex-col items-center gap-2 md:w-[215px]">
          <div class="w-[55px] h-[55px] mb-2 md:mb-4">
            <img src="/assets/icon3.png" alt="Non-sticky, separate grains" class="w-full h-full object-contain" />
          </div>
          <p class="font-montserrat font-semibold text-[16px] md:text-[22px] leading-snug md:leading-[36px] text-center text-white">
            Non-sticky, separate grains
          </p>
        </div>
        <div class="flex flex-col items-center gap-2 md:w-[215px]">
          <div class="w-[55px] h-[55px] mb-2 md:mb-4">
            <img src="/assets/icon4.png" alt="Soft, fluffy texture after cooking" class="w-full h-full object-contain" />
          </div>
          <p class="font-montserrat font-semibold text-[16px] md:text-[22px] leading-snug md:leading-[36px] text-center text-white">
            Soft, fluffy texture after cooking
          </p>
        </div>
      </div>
    </div>
  </section>
  <StatBanner />
  <ProductsComponent />
  <MillingProcess />
  <br><br><br><br>
  <PrivateLabel />
  <br><br><br><br>
  <Footer />
</Layout>
