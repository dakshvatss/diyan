---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Products — Diyan Rice Mill Industry"
  description="Explore our range of premium rice products."
>
  <Header />
  <img src="public/assets/woodrice.png" alt="woodrice" />

  <!-- Green Stat Section: Indian Basmati is globally recognized for (copied from index.html) -->
  <section class="w-full bg-primary py-16 md:py-0 md:h-[473px] flex items-center">
    <div class="max-w-[1440px] mx-auto px-6 md:px-16 w-full">
      <!-- Section Heading -->
      <h2 class="font-montserrat font-bold text-[26px] md:text-[42px] leading-tight md:leading-[51px] text-center text-white mb-10 md:mb-16">
        Indian Basmati is globally recognized for
      </h2>
      <!-- Feature Cards -->
      <div class="grid grid-cols-2 md:flex md:flex-row md:justify-center md:items-start gap-8 md:gap-[84px]">
        <div class="flex flex-col items-center gap-2 md:w-[215px]">
          <div class="w-[55px] h-[55px] mb-2 md:mb-4">
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Elongated grain shape -->
              <ellipse cx="32" cy="32" rx="10" ry="28" fill="white" opacity="0.9"/>
              <ellipse cx="32" cy="16" rx="6" ry="12" fill="white"/>
              <ellipse cx="32" cy="48" rx="6" ry="12" fill="white"/>
              <line x1="14" y1="32" x2="50" y2="32" stroke="white" stroke-width="2.5" stroke-dasharray="4 3"/>
            </svg>
          </div>
          <p class="font-montserrat font-semibold text-[16px] md:text-[22px] leading-snug md:leading-[36px] text-center text-white">
            Extra-long slender grains
          </p>
        </div>
        <div class="flex flex-col items-center gap-2 md:w-[215px]">
          <div class="w-[55px] h-[55px] mb-2 md:mb-4">
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Aroma / steam waves -->
              <path d="M20 44 Q20 36 28 32 Q36 28 36 20" stroke="white" stroke-width="3" stroke-linecap="round" fill="none"/>
              <path d="M32 48 Q32 38 40 34 Q48 30 48 20" stroke="white" stroke-width="3" stroke-linecap="round" fill="none"/>
              <path d="M8 46 Q8 38 16 33 Q24 28 24 18" stroke="white" stroke-width="3" stroke-linecap="round" fill="none"/>
            </svg>
          </div>
          <p class="font-montserrat font-semibold text-[16px] md:text-[22px] leading-snug md:leading-[36px] text-center text-white">
            Distinct natural aroma
          </p>
        </div>
        <div class="flex flex-col items-center gap-2 md:w-[215px]">
          <div class="w-[55px] h-[55px] mb-2 md:mb-4">
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Three separated grain ovals -->
              <ellipse cx="16" cy="32" rx="8" ry="18" fill="white" opacity="0.9"/>
              <ellipse cx="32" cy="32" rx="8" ry="18" fill="white"/>
              <ellipse cx="48" cy="32" rx="8" ry="18" fill="white" opacity="0.9"/>
            </svg>
          </div>
          <p class="font-montserrat font-semibold text-[16px] md:text-[22px] leading-snug md:leading-[36px] text-center text-white">
            Non-sticky, separate grains
          </p>
        </div>
        <div class="flex flex-col items-center gap-2 md:w-[215px]">
          <div class="w-[55px] h-[55px] mb-2 md:mb-4">
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Bowl with steam -->
              <path d="M12 36 Q12 52 32 52 Q52 52 52 36 L12 36Z" fill="white" opacity="0.9"/>
              <rect x="8" y="34" width="48" height="4" rx="2" fill="white"/>
              <path d="M24 28 Q24 22 28 20 Q32 18 32 12" stroke="white" stroke-width="2.5" stroke-linecap="round" fill="none"/>
              <path d="M32 28 Q32 22 36 20 Q40 18 40 12" stroke="white" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            </svg>
          </div>
          <p class="font-montserrat font-semibold text-[16px] md:text-[22px] leading-snug md:leading-[36px] text-center text-white">
            Soft, fluffy texture after cooking
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
